#!/bin/bash
LOG_FILE="${TRIM_DATA_SHARE_PATHS%%:*}/info.log"
PID_FILE="${TRIM_PKGVAR}/app.pid"
CONFIG_DIR="${TRIM_DATA_SHARE_PATHS%%:*}/config"

CONFIG_TEMPLATE="${TRIM_APPDEST}/template/default.tpl"
CONFIG_FILE="${TRIM_DATA_SHARE_PATHS%%:*}/config/default.toml"

LOG_OPT="--file-log-dir ${TRIM_DATA_SHARE_PATHS%%:*}"
LOG_OPT="${LOG_OPT} --file-log-level $log_level"
LOG_OPT="${LOG_OPT} --file-log-size $log_size"
LOG_OPT="${LOG_OPT} --file-log-count $log_count"
RPC_OPT="--rpc-portal $rpc_addr"
if [ "$rpc_whitelist_mode" = "on" ]; then
    RPC_OPT="${RPC_OPT} --rpc-portal-whitelist $rpc_whitelist"
fi



log_msg() {
    echo "$(date '+%Y-%m-%d %H:%M:%S') - $1" >> ${LOG_FILE}
}

stop_process() {
    log_msg "Stopping process ..."

    for process_name in easytier-web-em easytier-core; do
        log_msg "Looking for process: $process_name"
        pids=$(pgrep -f "$process_name" 2>/dev/null)
        if [ -n "$pids" ]; then
            log_msg "Found $process_name processes: $pids"
            for pid in $pids; do
                if check_process "$pid"; then
                    log_msg "Sending TERM signal to $process_name (PID: $pid)"
                    kill -TERM "$pid" 2>&1
                fi
            done
            for ((i=1; i<=5; i++)); do
                remaining_pids=$(pgrep -f "$process_name" 2>/dev/null)
                [ -z "$remaining_pids" ] && break
                sleep 1
                log_msg "Waiting for $process_name to terminate... (${i}s/5s)"
            done
            remaining_pids=$(pgrep -f "$process_name" 2>/dev/null)
            if [ -n "$remaining_pids" ]; then
                log_msg "Sending KILL signal to remaining $process_name processes: $remaining_pids"
                kill -KILL $remaining_pids 2>/dev/null
            fi
        else
            log_msg "No $process_name processes found"
        fi
    done

    rm -f "$PID_FILE"
    log_msg "Stop command completed."
    return 0
}

start_process() {
    log_msg "Start process initiated. Ensuring old processes are stopped first..."
    stop_process

    local core_pid
    if [ "$easytier_mode" = "config" ]; then
        if [ -z "$(find "$CONFIG_DIR" -maxdepth 1 -name '*.toml' -print -quit)" ]; then
            echo "错误：应用文件/EasyTier/config目录未找到toml文件" > ${TRIM_TEMP_LOGFILE}
            exit 1
        fi
        log_msg "配置文件模式启动..."
        if [ "$rpc_mode" = "off" ]; then
            "${TRIM_APPDEST}/server/easytier-core" --config-dir "$CONFIG_DIR" $LOG_OPT 2>&1 &
        else
            "${TRIM_APPDEST}/server/easytier-core" --config-dir "$CONFIG_DIR" $RPC_OPT $LOG_OPT 2>&1 &
            log_msg "RPC控制已启动..."
        fi
        core_pid=$!
    elif [ "$easytier_mode" = "web" ]; then
        log_msg "web控制台模式启动..."
        "${TRIM_APPDEST}/server/easytier-web-embed" -a "$ui_port" -d "${TRIM_PKGHOME}/et.db" 2>&1 &
        "${TRIM_APPDEST}/server/easytier-core" -w "udp://127.0.0.1:22020/$ui_username" $LOG_OPT 2>&1 &
        core_pid=$!
    else
        if [ ! -f "$CONFIG_FILE" ]; then
            UUID=$(cat /proc/sys/kernel/random/uuid)
            sed \
              -e "s|\${CONFIG_NAME}|$config_name|g" \
              -e "s|\${CONFIG_SECRET}|$config_secret|g" \
              -e "s|\${PEER_URL}|$peer_url|g" \
              -e "s|\${UUID_ID}|$UUID|g" \
              "${CONFIG_TEMPLATE}" > "$CONFIG_FILE" 2>/dev/null
            log_msg "default配置文件不存在，已重新生成"
        fi
        log_msg "rpc远程控制模式启动..."
        "${TRIM_APPDEST}/server/easytier-core" --config-dir "$CONFIG_DIR" $RPC_OPT $LOG_OPT 2>&1 &
        core_pid=$!
    fi

    printf "%s" "$core_pid" > "$PID_FILE"
    log_msg "$easytier_mode模式启动完成..."
    return 0
}

check_process() {
    local pid=$1
    if kill -0 "${pid}" 2>/dev/null; then
        return 0  # process exist
    else
        return 1  # process not exist
    fi
}

status() {
    if [ -f "${PID_FILE}" ]; then
        pid=$(head -n 1 "${PID_FILE}" | tr -d '[:space:]')
        if check_process "${pid}"; then
            return 0
        else
            # Process is not running but pidfile exists - clean it up
            rm -f "${PID_FILE}"
        fi    
    fi

    return 1
}

case $1 in
start)
    # run start command. exit 0 if success, exit 1 if failed
    start_process
    ;;
stop)
    # run stop command. exit 0 if success, exit 1 if failed
    stop_process
    ;;
status)
    # check application status command. exit 0 if running, exit 3 if not running
    if status; then 
        exit 0
    else 
        exit 3
    fi
    ;;
*)
    exit 1
    ;;
esac
